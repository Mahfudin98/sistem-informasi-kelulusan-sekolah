{
    "name": "app/kelulusan",
    "description": "Aplikasi Pengecekan Kelulusan - PHP Native Modern MVC",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "dompdf/dompdf": "^3.1",
        "phpmailer/phpmailer": "^6.9",
        "phpoffice/phpspreadsheet": "^5.7",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^3.8",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "app/Core/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
